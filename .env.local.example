# aga2aga local environment — copy to .env.local and fill in values
# .env.local is gitignored; never commit real keys

# OpenRouter API key — required for /fix-review external model rounds
# Get one at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Ollama base URL — optional, used as /fix-review fallback if OpenRouter unavailable
# Default: http://localhost:11434
# OLLAMA_BASE_URL=http://localhost:11434
