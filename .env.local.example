# aga2aga local environment — copy to .env.local and fill in values.
# .env.local is gitignored; never commit real keys.

# ─── fix-review skill ────────────────────────────────────────────────────────

# OpenRouter API key — required when fix-review config.yaml sets provider: openrouter
# Get one at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Ollama API key — required when fix-review config.yaml sets provider: ollama
# Get one at: https://ollama.com/settings/keys
OLLAMA_API_KEY=...

# ─── live-test skill ─────────────────────────────────────────────────────────

# Admin UI password — used by /live-test to authenticate (default: changeme)
# Only needed if you changed the default password and want /live-test to log in automatically.
# ADMIN_PASSWORD=changeme
