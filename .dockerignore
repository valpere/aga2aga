# Version control
.git
.github

# Claude Code tooling — not needed in image
.claude

# Environment files — never bake secrets into images
.env
.env.*
!.env.local.example

# Private key material (future phases)
*.pem
*.key
*.p8

# Test data and docs — not part of the binary
tests/
schemas/
docs/
*.md

# Build artifacts
*.out
coverage.*

# Editor / IDE
.idea/
.vscode/
